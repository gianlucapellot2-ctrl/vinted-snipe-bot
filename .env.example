# Discord Bot Token (von discord.com/developers)
DISCORD_BOT_TOKEN=dein_token_hier

# Vinted Scraper-Account Cookie (kompletter String aus Browser)
# So holen: F12 → Network → vinted.de Request → Headers → "Cookie:" Zeile kopieren
VINTED_COOKIES=access_token_web=xxx; refresh_token_web=xxx; _vinted_fr_session=xxx; anon_id=xxx

# Vinted Domain (vinted.de, vinted.at, vinted.fr, etc.)
VINTED_DOMAIN=vinted.de

# Poll-Intervall in Sekunden (4 = schnellster stabiler Wert)
POLL_INTERVAL=4

# Deine Discord User ID (für Token-Ablauf-Benachrichtigungen)
# Einstellungen → Erweitert → Entwicklermodus → Rechtsklick auf dich → ID kopieren
BOT_OWNER_ID=deine_discord_user_id
